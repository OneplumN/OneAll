# OneAll 环境变量配置文件
# 复制此文件为 .env 并修改配置

# ============ 安全配置 ============
# Django 密钥（生产环境请使用随机长字符串）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-change-in-production
ITSM_CALLBACK_SECRET=change-this-callback-secret

# ============ 数据库密码 ============
MYSQL_ROOT_PASSWORD=oneall123
TIMESCALE_PASSWORD=oneall123

# ============ 探针配置 ============
# 探针 ID 和 Token（需要先在界面注册探针后获取）
PROBE_NODE_ID=
PROBE_API_TOKEN=
