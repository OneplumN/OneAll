# OneAll 环境变量配置文件
# 复制此文件为 .env 并修改配置

# ============ 安全配置 ============
# Django 密钥（生产环境请使用随机长字符串）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-change-in-production
ITSM_CALLBACK_SECRET=change-this-callback-secret
CONSOLE_BASE_URL=http://localhost

# ============ 数据库密码 ============
MYSQL_ROOT_PASSWORD=oneall123
TIMESCALE_PASSWORD=oneall123

# ============ 探针配置 ============
# 仅当后端启用了引导校验时才需要配置
PROBE_BOOTSTRAP_TOKEN=
# 如需复用已有探针节点，可选填写以下凭据；留空时 probe 会自动注册
PROBE_NODE_ID=
PROBE_API_TOKEN=
# 自动注册时使用的节点展示信息
PROBE_LOCATION=Docker Probe
PROBE_NETWORK_TYPE=internal
# 如需覆盖 metrics 端口，可选填写
PROBE_METRICS_ADDR=:9100
